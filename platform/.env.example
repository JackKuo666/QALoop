# 必填：JWT 密钥（生产环境务必修改为随机字符串）
SECRET_KEY=change-me-to-a-random-secret-key

# 环境类型：development / production
ENVIRONMENT=development

# 服务器配置
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Token 过期天数
TOKEN_EXPIRE_DAYS=7

# LLM 配置（可选；未设置时使用 Demo 默认值）
# LLM_API_KEY=your-token-here
# LLM_BASE_URL=http://43.159.131.233:3001/v1
# LLM_MODEL_NAME=gpt-5.1
